# Copy to .env and tweak for your environment.
# Both ws-services and ws-calculator read these via Viper (envvar binding,
# dots in property names map to underscores).

SERVER_PORT_WS_SERVICES=8090
SERVER_PORT_WS_CALCULATOR=8091

DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=rainmaker

KAFKA_BROKERS=kafka:9092
KAFKA_GROUP_ID=egov-ws

IS_EXTERNAL_WORKFLOW_ENABLED=false
NOTIFICATION_SMS_ENABLED=false
NOTIFICATION_EMAIL_ENABLED=false
EGOV_USER_EVENT_NOTIFICATION_ENABLED=false
